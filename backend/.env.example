# Copy to .env for local development. Never commit the real .env file.
# See docs/deployment/docker-compose.md §5 and docs/deployment/local-development.md.

PORT=3000

# Container network (docker compose up backend): mongodb://mongodb:27017/ifoc
# Native host (npm run start:dev per local-development.md): mongodb://localhost:27017/ifoc
MONGODB_URI=mongodb://localhost:27017/ifoc

# Container network: kafka:9092
# Native host: localhost:9093 (PLAINTEXT_HOST listener — see docker-compose.md §4)
KAFKA_BROKERS=localhost:9093

KAFKA_TOPIC_MACHINE_EVENTS=machine.events

# Insight Service / LLM API credential — not used by this change (insights/ is out of scope), reserved for later.
LLM_API_KEY=
